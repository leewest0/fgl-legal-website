# ---------------------------------------------------------------------------
# FGL LEGAL — environment variables
# Copy this file to `.env.local` for local development, and set the same
# variables in your Vercel project (Settings → Environment Variables).
# The contact form works WITHOUT these — it degrades gracefully and logs the
# submission — but email delivery is only enabled once RESEND_API_KEY is set.
# ---------------------------------------------------------------------------

# Resend API key (https://resend.com — free tier). Enables contact-form email.
RESEND_API_KEY=

# Where contact submissions are delivered (defaults to info@fgllegalgh.com).
CONTACT_TO=info@fgllegalgh.com

# Verified "from" address. Resend's onboarding@resend.dev works immediately;
# switch to an address on your verified domain in production.
CONTACT_FROM="FGL LEGAL Website <onboarding@resend.dev>"
